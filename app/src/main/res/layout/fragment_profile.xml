<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg">

    <View
        android:id="@+id/ed_li_header_bg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@color/brown_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ed_li_iv_profile"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/brown_user"
        app:layout_constraintBottom_toBottomOf="@id/ed_li_header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_header_bg"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
        app:strokeColor="@color/cream_bg"
        app:strokeWidth="4dp" />

    <TextView
        android:id="@+id/ed_li_tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Elisabed Dvalishvili"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/brown_dark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_iv_profile" />

    <TextView
        android:id="@+id/ed_li_tv_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IT Auditor"
        android:textSize="18sp"
        android:textColor="@color/brown_primary"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_tv_name" />

    <LinearLayout
        android:id="@+id/ed_li_info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/ed_li_tv_role">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age"
                android:textSize="12sp"
                android:textColor="@color/brown_light" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/brown_dark" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="@color/accent_tan" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="University"
                android:textSize="12sp"
                android:textColor="@color/brown_light" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTU"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/brown_dark" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/ed_li_tv_project"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Advanced Wealth Tracker Project"
        android:textSize="14sp"
        android:alpha="0.7"
        android:textColor="@color/brown_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_info_container" />

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/ed_li_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="48dp"
        app:dividerColor="@color/accent_tan"
        app:layout_constraintTop_toBottomOf="@id/ed_li_tv_project" />

    <TextView
        android:id="@+id/ed_li_tv_final_savings_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Latest Savings: 0.00 ₾"
        android:textSize="14sp"
        android:textColor="@color/brown_dark"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_divider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Formula: (8 + 10) / 11 = 1.64"
        android:textStyle="italic"
        android:textSize="12sp"
        android:textColor="@color/brown_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_li_tv_final_savings_profile" />

</androidx.constraintlayout.widget.ConstraintLayout>
